# Windows Docker Desktop — copy to .env (optional)
#   Copy-Item .env.example .env

# Optional HTTPS webhook (env name referenced by policy).
IBN_WEBHOOK_URL=

# Optional alternate policy bind-mounted into the container.
# IBN_POLICY=./config/policy.v2.docker.json

# Optional pcap for: docker compose --profile replay run --rm replay
# IBN_PCAP=./test-traffic.pcap
