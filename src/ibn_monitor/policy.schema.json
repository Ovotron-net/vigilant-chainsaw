{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ibn-monitor/policy.schema.json",
  "title": "IBN Continuous Traffic Monitor Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "const": 1 },
    "sensor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interface": { "type": ["string", "null"], "minLength": 1 },
        "bpf_filter": { "type": "string", "minLength": 1 },
        "promiscuous": { "type": "boolean" }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "max_bytes": { "type": "integer", "minimum": 1024 },
        "backup_count": { "type": "integer", "minimum": 1 }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "bind": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "webhook_url_env": { "type": ["string", "null"], "minLength": 1 },
        "timeout_seconds": { "type": "number", "minimum": 0.1 },
        "minimum_severity": {
          "enum": ["low", "medium", "high", "critical"]
        },
        "deduplication_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "source_cidrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "destination_cidrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "protocol": { "enum": ["any", "tcp", "udp", "icmp"] },
        "destination_ports": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
        },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "action": { "enum": ["alert", "drop"] }
      }
    }
  }
}
